{
  "name": "linc-editorial-signal-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "setup:notion": "tsx src/cli.ts setup:notion",
    "sync:daily": "tsx src/cli.ts sync:daily",
    "digest:send": "tsx src/cli.ts digest:send",
    "selection:scan": "tsx src/cli.ts selection:scan",
    "profile:weekly-recompute": "tsx src/cli.ts profile:weekly-recompute",
    "cleanup:retention": "tsx src/cli.ts cleanup:retention",
    "backfill": "tsx src/cli.ts backfill"
  },
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "@prisma/client": "^6.5.0",
    "@slack/web-api": "^7.11.0",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
