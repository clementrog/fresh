generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourceCursor {
  id         String   @id
  companyId  String?
  source     String
  cursor     String?
  updatedAt  DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([companyId, source])
  @@index([companyId, source])
}

model SourceItem {
  id               String   @id
  companyId         String
  source           String
  sourceItemId     String
  externalId       String
  fingerprint      String
  sourceUrl        String
  title            String
  summary          String
  text             String
  authorName       String?
  speakerName      String?
  occurredAt       DateTime
  ingestedAt       DateTime
  metadataJson     Json
  rawPayloadJson   Json
  rawText          String?
  chunksJson       Json?
  rawTextStored    Boolean  @default(true)
  rawTextExpiresAt DateTime?
  cleanupEligible  Boolean  @default(false)
  notionPageId     String?
  notionPageFingerprint String?
  processedAt      DateTime?
  screeningResultJson Json?

  evidenceReferences EvidenceReference[]
  signalSourceItems  SignalSourceItem[]
  company            Company @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([companyId, source, sourceItemId])
  @@unique([companyId, fingerprint])
  @@index([source, occurredAt])
  @@index([cleanupEligible, rawTextExpiresAt])
  @@index([companyId, processedAt])
}

model EvidenceReference {
  id              String   @id
  signalId        String?
  opportunityId   String?
  draftId         String?
  companyId       String?
  sourceItemId    String
  source          String
  sourceUrl       String
  timestamp       DateTime
  excerpt         String
  excerptHash     String
  speakerOrAuthor String?
  freshnessScore  Float
  createdAt       DateTime @default(now())

  signal      Signal?      @relation(fields: [signalId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  draft       Draft?       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sourceItem  SourceItem   @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  primaryForOpportunities Opportunity[] @relation("PrimaryOpportunityEvidence")
  opportunityLinks OpportunityEvidence[]

  @@unique([opportunityId, id])
  @@index([excerptHash])
  @@index([companyId, sourceItemId])
}

model OpportunityEvidence {
  opportunityId String
  evidenceId    String
  relevanceNote String   @default("")
  createdAt     DateTime @default(now())

  opportunity Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  evidence    EvidenceReference @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([opportunityId, evidenceId])
}

model Signal {
  id                    String   @id
  sourceFingerprint     String   @unique
  title                 String
  summary               String
  type                  String
  freshness             Float
  confidence            Float
  probableOwnerProfile  String?
  suggestedAngle        String
  status                String
  sensitivityJson       Json
  duplicateOfSignalId   String?
  themeClusterKey       String?
  notionPageId          String?
  notionPageFingerprint String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  duplicateOf   Signal?          @relation("SignalDuplicate", fields: [duplicateOfSignalId], references: [id], onDelete: SetNull)
  duplicates    Signal[]         @relation("SignalDuplicate")
  evidence      EvidenceReference[]
  sourceItems   SignalSourceItem[]
  opportunities OpportunitySignal[]
  themeCluster  ThemeCluster?    @relation(fields: [themeClusterKey], references: [key], onDelete: SetNull)
}

model SignalSourceItem {
  signalId     String
  sourceItemId String

  signal     Signal     @relation(fields: [signalId], references: [id], onDelete: Cascade)
  sourceItem  SourceItem @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)

  @@id([signalId, sourceItemId])
}

model ThemeCluster {
  key          String   @id
  title        String
  profileHint  String?
  evidenceCount Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  signals Signal[]
}

model ProfileBase {
  profileId            String   @id
  companyId            String?
  role                 String
  languagePreference   String
  toneSummary          String
  preferredStructure   String
  typicalPhrasesJson   Json
  avoidRulesJson       Json
  contentTerritoriesJson Json
  weakFitTerritoriesJson Json
  sampleExcerptsJson   Json
  sourcePath           String
  notionPageId         String?
  notionPageFingerprint String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
}

model ProfileLearnedLayer {
  profileId               String @id
  recurringPhrasesJson    Json
  structuralPatternsJson  Json
  evidenceExcerptIdsJson  Json
  lastIncrementalUpdateAt DateTime
  lastWeeklyRecomputeAt   DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Opportunity {
  id                      String   @id
  companyId               String
  sourceFingerprint       String
  title                   String
  ownerProfile            String?
  ownerUserId             String?
  narrativePillar         String
  angle                   String
  whyNow                  String
  whatItIsAbout           String
  whatItIsNotAbout        String
  routingStatus           String
  readiness               String
  status                  String
  suggestedFormat         String
  supportingEvidenceCount Int
  evidenceFreshness       Float
  primaryEvidenceId       String?
  editorialOwner          String?
  selectedAt              DateTime?
  lastDigestAt            DateTime?
  enrichmentLogJson       Json     @default("[]")
  v1HistoryJson           Json
  notionPageId            String?
  notionPageFingerprint   String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  company         Company              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerUser       User?                @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  primaryEvidence EvidenceReference?   @relation("PrimaryOpportunityEvidence", fields: [primaryEvidenceId], references: [id], onDelete: SetNull)
  evidence        EvidenceReference[]
  linkedEvidence  OpportunityEvidence[]
  relatedSignals  OpportunitySignal[]
  drafts          Draft[]

  @@unique([companyId, sourceFingerprint])
}

model OpportunitySignal {
  opportunityId String
  signalId      String

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  signal      Signal      @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([opportunityId, signalId])
}

model NotionDatabaseBinding {
  id           String   @id
  companyId     String?
  name         String
  parentPageId String
  databaseId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([parentPageId, name])
  @@index([companyId, name])
}

model DigestDispatch {
  id                 String   @id
  digestKey          String   @unique
  status             String
  channel            String
  opportunityIdsJson Json
  slackMessageTs     String?
  sentAt             DateTime?
  leaseExpiresAt     DateTime?
  error              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Draft {
  id               String   @id
  companyId        String?
  opportunityId    String
  profileId        String
  proposedTitle    String
  hook             String
  summary          String
  whatItIsAbout    String
  whatItIsNotAbout String
  visualIdea       String
  firstDraftText   String
  confidenceScore  Float
  language         String
  createdAt        DateTime @default(now())

  company     Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunity Opportunity         @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  evidence    EvidenceReference[]
}

model SyncRun {
  id               String   @id
  companyId         String?
  runType          String
  source           String?
  status           String
  startedAt        DateTime
  finishedAt       DateTime?
  countersJson     Json
  warningsJson     Json
  notes            String?
  llmStatsJson     Json?
  tokenTotalsJson  Json?
  notionPageId     String?
  notionPageFingerprint String
  createdAt        DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  costEntries CostLedgerEntry[]
}

model CostLedgerEntry {
  id               String   @id
  step             String
  model            String
  mode             String
  promptTokens     Int
  completionTokens Int
  estimatedCostUsd Float
  runId            String
  createdAt        DateTime @default(now())

  run SyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Company {
  id              String   @id
  slug            String   @unique
  name            String
  defaultTimezone String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceCursors          SourceCursor[]
  sourceItems            SourceItem[]
  profileBases           ProfileBase[]
  opportunities          Opportunity[]
  notionDatabaseBindings NotionDatabaseBinding[]
  drafts                 Draft[]
  syncRuns               SyncRun[]
  users                  User[]
  editorialConfigs       EditorialConfig[]
  sourceConfigs          SourceConfig[]
  marketQueries          MarketQuery[]
  evidenceReferences     EvidenceReference[]
}

model User {
  id          String   @id
  companyId   String
  displayName String
  type        String
  language    String
  baseProfile Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedOpportunities Opportunity[]

  @@index([companyId])
}

model EditorialConfig {
  id                     String   @id
  companyId              String
  version                Int
  layer1CompanyLens      Json
  layer2ContentPhilosophy Json
  layer3LinkedInCraft    Json
  createdAt              DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version])
}

model SourceConfig {
  id         String   @id
  companyId  String
  source     String
  enabled    Boolean
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source])
}

model MarketQuery {
  id        String   @id
  companyId String
  query     String
  enabled   Boolean
  priority  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, enabled, priority])
}
