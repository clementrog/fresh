generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourceCursor {
  id         String   @id
  companyId  String?
  source     String
  cursor     String?
  updatedAt  DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([companyId, source])
  @@index([companyId, source])
}

model SourceItem {
  id               String   @id
  companyId         String
  source           String
  sourceItemId     String
  externalId       String
  fingerprint      String
  sourceUrl        String
  title            String
  summary          String
  text             String
  authorName       String?
  speakerName      String?
  occurredAt       DateTime
  ingestedAt       DateTime
  metadataJson     Json
  rawPayloadJson   Json
  rawText          String?
  chunksJson       Json?
  rawTextStored    Boolean  @default(true)
  rawTextExpiresAt DateTime?
  cleanupEligible  Boolean  @default(false)
  notionPageId     String?
  notionPageFingerprint String?
  processedAt      DateTime?
  screeningResultJson Json?

  evidenceReferences EvidenceReference[]
  salesSignals       SalesSignal[]
  company            Company @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([companyId, source, sourceItemId])
  @@unique([companyId, fingerprint])
  @@index([source, occurredAt])
  @@index([cleanupEligible, rawTextExpiresAt])
  @@index([companyId, processedAt])
}

model EvidenceReference {
  id              String   @id
  opportunityId   String?
  draftId         String?
  companyId       String?
  sourceItemId    String
  source          String
  sourceUrl       String
  timestamp       DateTime
  excerpt         String
  excerptHash     String
  speakerOrAuthor String?
  freshnessScore  Float
  createdAt       DateTime @default(now())

  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  draft       Draft?       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sourceItem  SourceItem   @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  primaryForOpportunities Opportunity[] @relation("PrimaryOpportunityEvidence")
  opportunityLinks OpportunityEvidence[]
  recommendationLinks RecommendationEvidence[]

  @@unique([opportunityId, id])
  @@index([excerptHash])
  @@index([companyId, sourceItemId])
}

model OpportunityEvidence {
  opportunityId String
  evidenceId    String
  relevanceNote String   @default("")
  createdAt     DateTime @default(now())

  opportunity Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  evidence    EvidenceReference @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([opportunityId, evidenceId])
}

model Opportunity {
  id                      String   @id
  companyId               String
  sourceFingerprint       String
  title                   String
  ownerProfile            String?
  ownerUserId             String?
  narrativePillar         String?  @default("")
  targetSegment           String?  @default("")
  editorialPillar         String?  @default("")
  awarenessTarget         String?  @default("")
  buyerFriction           String?  @default("")
  contentMotion           String?  @default("")
  angle                   String
  editorialClaim          String?  @default("")
  whyNow                  String
  whatItIsAbout           String
  whatItIsNotAbout        String
  routingStatus           String?  @default("Routed")
  readiness               String?  @default("Opportunity only")
  status                  String
  suggestedFormat         String
  supportingEvidenceCount Int
  evidenceFreshness       Float
  primaryEvidenceId       String?
  editorialOwner          String?
  editorialNotes          String?  @default("")
  dedupFlag               String?  @default("")
  notionEditsPending      Boolean  @default(false)
  selectedAt              DateTime?
  lastDigestAt            DateTime?
  enrichmentLogJson       Json     @default("[]")
  v1HistoryJson           Json?    @default("[]")
  notionPageId            String?
  notionPageFingerprint   String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  company         Company              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerUser       User?                @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  primaryEvidence EvidenceReference?   @relation("PrimaryOpportunityEvidence", fields: [primaryEvidenceId], references: [id], onDelete: SetNull)
  evidence        EvidenceReference[]
  linkedEvidence  OpportunityEvidence[]
  drafts          Draft[]

  @@unique([companyId, sourceFingerprint])
}

model NotionDatabaseBinding {
  id           String   @id
  companyId     String?
  name         String
  parentPageId String
  databaseId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([parentPageId, name])
  @@index([companyId, name])
}

model Draft {
  id               String   @id
  companyId        String?
  opportunityId    String
  profileId        String
  proposedTitle    String
  hook             String
  summary          String
  whatItIsAbout    String
  whatItIsNotAbout String
  visualIdea       String
  firstDraftText   String
  confidenceScore  Float
  language         String
  createdAt        DateTime @default(now())

  company     Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunity Opportunity         @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  evidence    EvidenceReference[]
}

model SyncRun {
  id               String   @id
  companyId         String?
  runType          String
  source           String?
  status           String
  startedAt        DateTime
  finishedAt       DateTime?
  countersJson     Json
  warningsJson     Json
  notes            String?
  llmStatsJson     Json?
  tokenTotalsJson  Json?
  notionPageId     String?
  notionPageFingerprint String
  leaseExpiresAt   DateTime?
  createdAt        DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  costEntries CostLedgerEntry[]
}

model CostLedgerEntry {
  id               String   @id
  step             String
  model            String
  mode             String
  promptTokens     Int
  completionTokens Int
  estimatedCostUsd Float
  runId            String
  createdAt        DateTime @default(now())

  run SyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model Company {
  id              String   @id
  slug            String   @unique
  name            String
  defaultTimezone String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceCursors          SourceCursor[]
  sourceItems            SourceItem[]
  opportunities          Opportunity[]
  notionDatabaseBindings NotionDatabaseBinding[]
  drafts                 Draft[]
  syncRuns               SyncRun[]
  users                  User[]
  editorialConfigs       EditorialConfig[]
  sourceConfigs          SourceConfig[]
  marketQueries          MarketQuery[]
  evidenceReferences     EvidenceReference[]

  // Sales relations
  salesDeals              SalesDeal[]
  salesContacts           SalesContact[]
  salesHubspotCompanies   SalesHubspotCompany[]
  salesActivities         SalesActivity[]
  salesSignals            SalesSignal[]
  salesExtractedFacts     SalesExtractedFact[]
  salesRecommendations    SalesRecommendation[]
  salesDrafts             SalesDraft[]
  salesDoctrines          SalesDoctrine[]
}

model User {
  id          String   @id
  companyId   String
  displayName String
  type        String
  language    String
  baseProfile Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedOpportunities     Opportunity[]
  salesRecommendations   SalesRecommendation[]
  recommendationActions  RecommendationAction[]

  @@index([companyId])
}

model EditorialConfig {
  id                     String   @id
  companyId              String
  version                Int
  layer1CompanyLens      Json
  layer2ContentPhilosophy Json
  layer3LinkedInCraft    Json
  createdAt              DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version])
}

model SourceConfig {
  id         String   @id
  companyId  String
  source     String
  enabled    Boolean
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source])
}

model MarketQuery {
  id        String   @id
  companyId String
  query     String
  enabled   Boolean
  priority  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, enabled, priority])
}

// ===========================================================================
// Fresh Sales models
// ===========================================================================

model SalesDeal {
  id                String   @id
  companyId         String
  hubspotDealId     String
  dealName          String
  pipeline          String
  stage             String
  amount            Float?
  ownerEmail        String?
  hubspotOwnerId    String?
  lastActivityDate  DateTime?
  closeDateExpected DateTime?
  propertiesJson    Json     @default("{}")
  staleDays         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts     DealContact[]
  companies    DealCompany[]
  activities   SalesActivity[]
  signals      SalesSignal[]
  extractions  SalesExtractedFact[]
  recommendations SalesRecommendation[]

  @@unique([companyId, hubspotDealId])
  @@index([companyId, stage])
  @@index([companyId, staleDays])
}

model SalesContact {
  id               String   @id
  companyId        String
  hubspotContactId String
  email            String?
  firstName        String?
  lastName         String?
  title            String?
  company          String?
  propertiesJson   Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentCompany Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals         DealContact[]
  activities    SalesActivity[]

  @@unique([companyId, hubspotContactId])
}

model SalesHubspotCompany {
  id                String   @id
  companyId         String
  hubspotCompanyId  String
  name              String
  domain            String?
  industry          String?
  size              String?
  propertiesJson    Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parentCompany Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals         DealCompany[]

  @@unique([companyId, hubspotCompanyId])
}

model DealContact {
  dealId    String
  contactId String

  deal    SalesDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact SalesContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
}

model DealCompany {
  dealId             String
  salesCompanyId     String

  deal    SalesDeal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  company SalesHubspotCompany @relation(fields: [salesCompanyId], references: [id], onDelete: Cascade)

  @@id([dealId, salesCompanyId])
}

model SalesActivity {
  id                   String    @id
  companyId            String
  hubspotEngagementId  String
  type                 String
  body                 String?
  timestamp            DateTime
  dealId               String?
  contactId            String?
  extractedAt          DateTime?
  rawTextExpiresAt     DateTime?
  rawTextCleaned       Boolean   @default(false)
  extractionAttempts   Int       @default(0)
  createdAt            DateTime  @default(now())

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal        SalesDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact     SalesContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  extractions SalesExtractedFact[]

  @@unique([companyId, hubspotEngagementId])
  @@index([companyId, dealId])
  @@index([extractedAt])
  @@index([rawTextCleaned, rawTextExpiresAt])
}

model SalesSignal {
  id           String   @id
  companyId    String
  signalType   String
  title        String
  description  String
  sourceItemId String?
  dealId       String?
  confidence   String
  metadataJson Json     @default("{}")
  matchedAt    DateTime?
  detectedAt   DateTime
  createdAt    DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceItem   SourceItem?  @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)
  deal         SalesDeal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  recommendations SalesRecommendation[]

  @@index([companyId, signalType])
  @@index([companyId, matchedAt])
  @@index([companyId, detectedAt])
}

model SalesExtractedFact {
  id             String   @id
  companyId      String
  activityId     String?
  dealId         String
  category       String
  label          String
  extractedValue String
  confidence     Float
  sourceText     String
  createdAt      DateTime @default(now())

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity SalesActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  deal     SalesDeal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([companyId, dealId])
  @@index([companyId, category])
}

model SalesRecommendation {
  id                 String    @id
  companyId          String
  dealId             String
  signalId           String
  userId             String?
  whyNow             String
  recommendedAngle   String
  nextStepType       String
  matchedContextJson Json      @default("{}")
  confidence         String
  priorityRank       Float     @default(0)
  status             String    @default("new")
  dismissReason      String?
  snoozedUntil       DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal     SalesDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  signal   SalesSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  user     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  evidence RecommendationEvidence[]
  actions  RecommendationAction[]
  drafts   SalesDraft[]

  @@index([companyId, status])
  @@index([companyId, dealId])
  @@index([companyId, userId, status])
  @@index([companyId, priorityRank])
}

model RecommendationEvidence {
  recommendationId String
  evidenceId       String
  relevanceNote    String   @default("")
  createdAt        DateTime @default(now())

  recommendation SalesRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  evidence       EvidenceReference   @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([recommendationId, evidenceId])
}

model RecommendationAction {
  id               String   @id
  recommendationId String
  userId           String?
  actionType       String
  reason           String?
  metadataJson     Json     @default("{}")
  createdAt        DateTime @default(now())

  recommendation SalesRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([recommendationId, actionType])
  @@index([recommendationId, createdAt])
}

model SalesDraft {
  id               String   @id
  companyId        String
  recommendationId String
  channelType      String
  subject          String?
  body             String
  repProfileId     String?
  confidenceScore  Float
  createdAt        DateTime @default(now())

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recommendation SalesRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([companyId, recommendationId])
}

model SalesDoctrine {
  id           String   @id
  companyId    String
  version      Int
  doctrineJson Json
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, version])
  @@index([companyId])
}
